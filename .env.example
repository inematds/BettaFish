# ====================== BETTAFISH - Configuracao ======================
# Endereco do host BETTAFISH, ex: 0.0.0.0 ou 127.0.0.1
HOST=0.0.0.0
# Porta do host BETTAFISH, padrao 5000
PORT=5000

# ====================== Configuracao do Banco de Dados ======================
# Host do banco de dados, ex: localhost ou 127.0.0.1
DB_HOST=your_db_host
# Porta do banco de dados, padrao 3306
DB_PORT=3306
# Usuario do banco de dados
DB_USER=your_db_user
# Senha do banco de dados
DB_PASSWORD=your_db_password
# Nome do banco de dados
DB_NAME=your_db_name
# Charset do banco de dados, recomendado utf8mb4, compativel com emoji
DB_CHARSET=utf8mb4
# Tipo de banco de dados: mysql ou postgresql
DB_DIALECT=postgresql

# ======================= Configuracao LLM =======================
# Voce pode alterar a API LLM usada em cada secao. Qualquer API compativel com o formato de requisicao OpenAI pode ser usada, basta definir KEY, BASE_URL e MODEL_NAME.
# Aviso importante: Recomendamos fortemente que voce primeiro solicite a API com a configuracao recomendada, teste e so entao faca suas alteracoes!
# Nossos patrocinadores de API de modelos LLM: https://aihubmix.com/?aff=8Ds9, oferecendo APIs de modelos muito completas

# Insight Agent (recomendado kimi-k2, endereco oficial: https://platform.moonshot.cn/)
INSIGHT_ENGINE_API_KEY=
INSIGHT_ENGINE_BASE_URL=
INSIGHT_ENGINE_MODEL_NAME=

# Media Agent (recomendado gemini-2.5-pro, endereco do provedor intermediario: https://aihubmix.com/?aff=8Ds9)
MEDIA_ENGINE_API_KEY=
MEDIA_ENGINE_BASE_URL=
MEDIA_ENGINE_MODEL_NAME=

# Query Agent (recomendado deepseek-chat, endereco oficial: https://platform.deepseek.com/)
QUERY_ENGINE_API_KEY=
QUERY_ENGINE_BASE_URL=
QUERY_ENGINE_MODEL_NAME=

# Report Agent (recomendado gemini-2.5-pro, endereco do provedor intermediario: https://aihubmix.com/?aff=8Ds9)
# Observacao: Report Agent requer capacidade de modelo relativamente forte; se o relatorio final apresentar graficos em branco/paragrafos anomalos, tente trocar para um modelo mais forte
REPORT_ENGINE_API_KEY=
REPORT_ENGINE_BASE_URL=
REPORT_ENGINE_MODEL_NAME=

# MindSpider Agent (recomendado deepseek-chat, endereco oficial: https://platform.deepseek.com/)
MINDSPIDER_API_KEY=
MINDSPIDER_BASE_URL=
MINDSPIDER_MODEL_NAME=

# Moderador do Forum (recomendado qwen-plus, endereco oficial: https://www.aliyun.com/product/bailian)
FORUM_HOST_API_KEY=
FORUM_HOST_BASE_URL=
FORUM_HOST_MODEL_NAME=

# SQL Keyword Optimizer (recomendado qwen-plus, endereco oficial: https://www.aliyun.com/product/bailian)
KEYWORD_OPTIMIZER_API_KEY=
KEYWORD_OPTIMIZER_BASE_URL=
KEYWORD_OPTIMIZER_MODEL_NAME=

# ================== Configuracao de Ferramentas de Rede ====================
# Chave API Tavily, usada para busca web Tavily, endereco de solicitacao: https://www.tavily.com/
TAVILY_API_KEY=

# Tipo de ferramenta de busca web, suporta BochaAPI ou AnspireAPI, padrao AnspireAPI
SEARCH_TOOL_TYPE=AnspireAPI

# Anspire AI Search API (endereco de solicitacao: https://open.anspire.cn/?share_code=3E1FUOUH, custo e metade do Bocha com o mesmo efeito)
ANSPIRE_BASE_URL=https://plugin.anspire.cn/api/ntsearch/search
ANSPIRE_API_KEY=

# Bocha AI Search API (usada para busca multimodal Bocha; embora o nome da chave seja Web Search, na verdade e para AI Search; endereco de solicitacao: https://open.bochaai.com/)
BOCHA_BASE_URL=https://api.bocha.cn/v1/ai-search
BOCHA_WEB_SEARCH_API_KEY=
